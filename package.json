{
  "name": "fitlook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run mobile",
    "android": "npm run mobile:android",
    "dev": "vite",
    "server": "node server/index.js",
    "server:watch": "nodemon server/index.js",
    "expo": "cd mobile && /opt/homebrew/opt/node@20/bin/node node_modules/expo/bin/cli start",
    "mobile": "cd mobile && /opt/homebrew/opt/node@20/bin/node node_modules/expo/bin/cli start --port 8081",
    "mobile:android": "cd mobile && /opt/homebrew/opt/node@20/bin/node node_modules/expo/bin/cli start --android --port 8081",
    "mobile:ios": "cd mobile && /opt/homebrew/opt/node@20/bin/node node_modules/expo/bin/cli start --ios --port 8081",
    "mobile:web": "cd mobile && /opt/homebrew/opt/node@20/bin/node node_modules/expo/bin/cli start --web --port 8081",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
